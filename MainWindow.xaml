<Window x:Class="postitSimulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Width="250"
        Height="300"
        ResizeMode="NoResize"
        MouseLeftButtonUp="Window_MouseLeftButtonUp"
        MouseRightButtonUp="Window_MouseRightButtonUp"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>

        <!-- ContextMenu -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="BorderBrush" Value="#3E3E42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="Button" x:Key="ColorButtonStyle">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderBrush" Value="#555"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="Black"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    <ContextMenu x:Key="GlobalMenu">
        <UniformGrid Rows="2" Columns="4">
            <Button Background="#FFF9F17F" Tag="0" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#7FF4FFF1" Tag="1" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#FFFDBA74" Tag="2" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#FFFFC1CC" Tag="3" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#FFBEEBC1" Tag="4" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#FFCBE7FF" Tag="5" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
            <Button Background="#FFFC9F9F" Tag="6" Style="{StaticResource ColorButtonStyle}" Click="ColorSelect_Click"/>
        </UniformGrid>
        <Separator/>
        <UniformGrid Rows="7" Columns="4">
            <Button Background="#7FF4FFF1" Content="🔍" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⋯" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⚙" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🎨" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="✒" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🖍" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🖌" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⏰" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="📅" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⏳" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⏱" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="⭐" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="❗" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="✔" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="❌" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🔒" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="🔓" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="💡" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="➕" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="✖" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="➖" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="💾" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="✏" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🗑" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>

            <Button Background="#7FF4FFF1" Content="📌" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="📝" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="🏷" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
            <Button Background="#7FF4FFF1" Content="📁" Style="{StaticResource ColorButtonStyle}" Click="IconSelect_Click"/>
           
        </UniformGrid>
        <Separator/>
        <MenuItem Header="🗑️ Excluir" Click="DeleteBtn_Click"/>
        <Separator/>
        <MenuItem Header="➕ Nova Polaroid" Click="AddPolaroid_Click"/>
        <MenuItem Header="➕ Novo Postit" Click="AddPostit_Click"/>
        <Separator/>
        <MenuItem Header="✕ Fechar" Click="CloseBtn_Click"/>
    </ContextMenu>

    </Window.Resources>

    <Window.RenderTransform>
        <ScaleTransform x:Name="WindowScale" ScaleX="1" ScaleY="1"/>
    </Window.RenderTransform>

    <Window.RenderTransformOrigin>
        <Point X="0.5" Y="0.5"/>
    </Window.RenderTransformOrigin>

    <Border x:Name="RootBorder">
        <Grid>
            <!-- VIEW NORMAL -->
            <Border x:Name="NormalView"
            Background="#FFF9F17F"
                CornerRadius="10">
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Border x:Name="NormalViewHeader"
                        Grid.Row="0"
                        Background="#FFEFE066"
                        CornerRadius="10,10,0,0"
                        MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
                        MouseMove="DragArea_MouseMove"
                        MouseLeftButtonUp="DragArea_MouseLeftButtonUp">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/> 
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                         <!-- BOTÃO ADICIONAR -->
                        <Button Content="+"
                                Grid.Column="0"
                                Width="20"
                                Height="20"
                                Margin="0,5,5,5"
                                Click="AddPostit_Click"
                                Background="Transparent"
                                BorderThickness="0">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border"
                                            Background="Transparent"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#3300ff62"/>
                                            <Setter Property="Foreground"
                                                    Value="Green"/>
                                        </Trigger>

                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border"
                                                    Property="Background"
                                                    Value="#6600ff62"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- TITULO -->
                        <TextBlock x:Name="TitlePost"
                                Grid.Column="1"
                                Text="Post-it"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                FontWeight="Bold"/>

                        <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                            <!-- BOTÃO MINIMIZAR -->
                            <Button Content="-"
                                    Width="20"
                                    Height="20"
                                    Margin="0,5,5,5"
                                    Click="MinimizeBtn_Click"
                                    Background="Transparent"
                                    BorderThickness="0">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="Transparent"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#335f625e"/>
                                                <Setter Property="Foreground"
                                                        Value="Gray"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#665f625e"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- BOTÃO FECHAR -->
                            <Button Content="✕"
                                    Width="20"
                                    Height="20"
                                    Margin="0,5,5,5"
                                    Click="CloseBtn_Click"
                                    Background="Transparent"
                                    BorderThickness="0">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="Transparent"
                                                CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#33FF0000"/>
                                                <Setter Property="Foreground"
                                                        Value="Red"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#66FF0000"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- TEXTO -->
                <TextBox x:Name="TextPost"
                         Grid.Row="1"
                         AcceptsReturn="True"
                         Background="Transparent"
                         BorderThickness="0"
                         FontSize="14"
                         TextWrapping="Wrap"
                         TextChanged="TextPost_changed"
                         Margin="10"/>
            </Grid>
            </Border>

            <!-- VIEW DOCK (TRIÂNGULO) -->
            <Grid x:Name="DockView"
                Visibility="Collapsed"
                MouseLeftButtonDown="DragArea_MouseLeftButtonDown"
                MouseMove="DragArea_MouseMove"
                MouseLeftButtonUp="DragArea_MouseLeftButtonUp">

                <Path x:Name="DockedPath"
                    Fill="#FFF9F17F"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                </Path>
                <TextBlock x:Name="IconPost"
                    Text="✏"
                    Foreground="Black"
                    FontSize="12"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Grid>

        </Grid>
    </Border>
</Window>